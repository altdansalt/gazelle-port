      "id": "go-native",
      "language": "Go",
      "scope": "//...",
      "rationale": "Gin is a single-module Go library with standard package layout (root package plus binding, render, codec, internal subpackages) and no proto/codegen, so native Gazelle Go generation over the whole tree is the natural path.",
      "module_bazel": "module(\n    name = \"gin\",\n    version = \"0.0.0\",\n)\n\nbazel_dep(name = \"rules_go\", version = \"0.61.1\")\nbazel_dep(name = \"gazelle\", version = \"0.51.3\")\n\ngo_sdk = use_extension(\"@rules_go//go:extensions.bzl\", \"go_sdk\")\ngo_sdk.download(version = \"1.25.4\")\n\ngo_deps = use_extension(\"@gazelle//:extensions.bzl\", \"go_deps\")\ngo_deps.from_file(go_mod = \"//:go.mod\")\n",
      "root_build": "load(\"@gazelle//:def.bzl\", \"gazelle\")\n\n# gazelle:prefix github.com/gin-gonic/gin\ngazelle(name = \"gazelle\")\n",
      "bazelrc": "common --enable_bzlmod\ntest --test_output=errors\n",
      "setup_commands": [
        "bazel run //:gazelle",
        "bazel mod tidy",
        "bazel build //...",
        "bazel test //..."
      ],
      "anticipated_risks": [
        "go:embed of testdata templates/certs may need data deps Gazelle should infer",
        "build-tagged files (context_appengine.go, binding_nomsgpack.go) selected via build constraints",
        "testdata/protoexample uses checked-in .pb.go (no codegen needed, but proto import may surface)",
        "tests relying on testdata file paths may need runfiles handling"
      ],
      "predicted_tier": 4
    }
