{
  "repo": "pallets/flask",
  "approaches": [
    {
      "id": "py-native",
      "language": "Python",
      "scope": "//src/...",
      "rationale": "Flask is a pure-Python library under src/flask with a standard pyproject. Use rules_python + its Gazelle plugin to generate py_library/py_test targets for the library, pulling third-party deps (werkzeug, jinja2, etc.) from a pip hub via uv.lock-derived requirements.",
      "module_bazel": "bazel_dep(name = \"rules_python\", version = \"2.0.2\")\nbazel_dep(name = \"rules_python_gazelle_plugin\", version = \"2.0.2\")\nbazel_dep(name = \"gazelle\", version = \"0.51.3\")\n\nPYTHON_VERSION = \"3.12\"\n\npython = use_extension(\"@rules_python//python/extensions:python.bzl\", \"python\")\npython.toolchain(\n    python_version = PYTHON_VERSION,\n    is_default = True,\n)\nuse_repo(python, \"python_3_12\")\n\npip = use_extension(\"@rules_python//python/extensions:pip.bzl\", \"pip\")\npip.parse(\n    hub_name = \"pip\",\n    python_version = PYTHON_VERSION,\n    requirements_lock = \"//:requirements.lock\",\n)\nuse_repo(pip, \"pip\")\n",
      "root_build": "load(\"@gazelle//:def.bzl\", \"gazelle\")\nload(\"@rules_python_gazelle_plugin//manifest:defs.bzl\", \"gazelle_python_manifest\")\nload(\"@rules_python_gazelle_plugin//modules_mapping:def.bzl\", \"modules_mapping\")\n\n# gazelle:python_root\n# gazelle:python_generation_mode package\n# gazelle:exclude examples\n# gazelle:exclude docs\n# gazelle:exclude tests/type_check\n# gazelle:resolve py flask //src/flask\n\nmodules_mapping(\n    name = \"modules_map\",\n    wheels = all_whl_requirements,\n)\n\ngazelle_python_manifest(\n    name = \"gazelle_python_manifest\",\n    modules_mapping = \":modules_map\",\n    pip_repository_name = \"pip\",\n    requirements = \"//:requirements.lock\",\n)\n\ngazelle(\n    name = \"gazelle\",\n    gazelle = \"@rules_python_gazelle_plugin//python:gazelle_binary\",\n)\n",
      "bazelrc": "common --enable_bzlmod\nbuild --incompatible_strict_action_env\ntest --test_output=errors\n",
      "setup_commands": [
        "uv export --no-hashes --format requirements-txt -o requirements.lock || uv pip compile pyproject.toml -o requirements.lock",
        "bazel run //:gazelle",
        "bazel run //:gazelle_python_manifest.update"
      ],
      "anticipated_risks": [
        "uv.lock to requirements.lock conversion may need manual pin of werkzeug/jinja2/click/blinker/itsdangerous/markupsafe",
        "tests rely on fixture data files (templates/, static/) needing data globs Gazelle may miss",
        "py.typed and namespace handling under src layout",
        "all_whl_requirements symbol must be loaded from @pip//:requirements.bzl (may need import adjustment after pip.parse)",
        "test discovery for conftest.py shared fixtures across tests/"
      ],
      "predicted_tier": 2
    }
  ]
}
