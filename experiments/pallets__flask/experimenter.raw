{
  "repo": "pallets/flask",
  "approaches": [
    {
      "id": "python-rules-python-gazelle",
      "language": "Python",
      "strategy": "A-gazelle",
      "ruleset": "rules_python_gazelle_plugin",
      "scope": "//...",
      "rationale": "Flask is a clean src-layout Python package with a uv.lock and a comprehensive pytest suite; rules_python's Gazelle plugin can generate py_library/py_test targets from imports, with deps resolved via pip.parse from a requirements lock.",
      "module_bazel": "module(\n    name = \"flask\",\n    version = \"0.0.0\",\n)\n\nbazel_dep(name = \"rules_python\", version = \"2.0.2\")\nbazel_dep(name = \"rules_python_gazelle_plugin\", version = \"2.0.2\")\nbazel_dep(name = \"gazelle\", version = \"0.51.3\")\n\npython = use_extension(\"@rules_python//python/extensions:python.bzl\", \"python\")\npython.toolchain(\n    python_version = \"3.12\",\n    is_default = True,\n)\nuse_repo(python, \"python_3_12\")\n\npip = use_extension(\"@rules_python//python/extensions:pip.bzl\", \"pip\")\npip.parse(\n    hub_name = \"pip\",\n    python_version = \"3.12\",\n    requirements_lock = \"//:requirements.lock\",\n)\nuse_repo(pip, \"pip\")\n",
      "root_build": "load(\"@gazelle//:def.bzl\", \"gazelle\")\nload(\"@rules_python_gazelle_plugin//manifest:defs.bzl\", \"gazelle_python_manifest\")\nload(\"@rules_python_gazelle_plugin//modules_mapping:def.bzl\", \"modules_mapping\")\n\n# gazelle:python_root\n# gazelle:python_generation_mode package\n# gazelle:exclude examples\n# gazelle:exclude docs\n\nmodules_mapping(\n    name = \"modules_map\",\n    wheels = all_whl_requirements,\n)\n\ngazelle_python_manifest(\n    name = \"gazelle_python_manifest\",\n    modules_mapping = \":modules_map\",\n    pip_repository_name = \"pip\",\n    requirements = \"//:requirements.lock\",\n)\n\ngazelle(\n    name = \"gazelle\",\n    gazelle = \"@rules_python_gazelle_plugin//python:gazelle_binary\",\n)\n",
      "bazelrc": "common --enable_bzlmod\nbuild --incompatible_strict_action_env\ntest --test_output=errors\n",
      "setup_commands": [
        "uv export --format requirements-txt --no-hashes -o requirements.lock || pip-compile -o requirements.lock pyproject.toml",
        "bazel run //:gazelle_python_manifest.update",
        "bazel run //:gazelle"
      ],
      "anticipated_risks": [
        "native wheels (markupsafe) in pip.parse",
        "test_apps fixtures with non-importable module names (flask.py shadow)",
        "data files (templates, static, .env) needing data attrs not inferred",
        "modules_mapping wiring requires all_whl_requirements load",
        "conftest.py fixture sharing across test dirs"
      ],
      "predicted_tier": 3
    },
    {
      "id": "python-gazelle-py",
      "language": "Python",
      "strategy": "A-gazelle",
      "ruleset": "gazelle_py",
      "scope": "//...",
      "rationale": "gazelle_py offers better pytest/conftest handling than the stock rules_python plugin, which matters for Flask's large suite with shared conftest fixtures and a test_apps tree; it reads pyproject.toml/uv.lock at the root directly.",
      "module_bazel": "module(\n    name = \"flask\",\n    version = \"0.0.0\",\n)\n\nbazel_dep(name = \"rules_python\", version = \"2.0.2\")\nbazel_dep(name = \"gazelle\", version = \"0.50.0\")\nbazel_dep(name = \"gazelle_py\", version = \"0.50.0\")\n\npython = use_extension(\"@rules_python//python/extensions:python.bzl\", \"python\")\npython.toolchain(\n    python_version = \"3.12\",\n    is_default = True,\n)\nuse_repo(python, \"python_3_12\")\n\npip = use_extension(\"@rules_python//python/extensions:pip.bzl\", \"pip\")\npip.parse(\n    hub_name = \"pip\",\n    python_version = \"3.12\",\n    requirements_lock = \"//:requirements.lock\",\n)\nuse_repo(pip, \"pip\")\n",
      "root_build": "load(\"@gazelle//:def.bzl\", \"gazelle\", \"gazelle_binary\")\n\n# gazelle:python_root\n# gazelle:exclude examples\n# gazelle:exclude docs\n\ngazelle_binary(\n    name = \"gazelle_bin\",\n    languages = [\"@gazelle_py//py\"],\n)\n\ngazelle(\n    name = \"gazelle\",\n    gazelle = \":gazelle_bin\",\n)\n",
      "bazelrc": "common --enable_bzlmod\ntest --test_output=errors\n",
      "setup_commands": [
        "uv export --format requirements-txt --no-hashes -o requirements.lock || pip-compile -o requirements.lock pyproject.toml",
        "bazel run //:gazelle"
      ],
      "anticipated_risks": [
        "native wheels (markupsafe) build under pip.parse",
        "gazelle_py BCR version pin compatibility with gazelle 0.50.0",
        "test_apps with deliberately broken/shadowing modules (inner2/flask.py)",
        "data deps for templates/static/sql fixtures",
        "type_check directory not meant to be executed as tests"
      ],
      "predicted_tier": 3
    }
  ]
}
