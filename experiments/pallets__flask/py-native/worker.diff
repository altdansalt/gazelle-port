diff --git a/.bazelrc b/.bazelrc
new file mode 100644
index 0000000..76fb815
--- /dev/null
+++ b/.bazelrc
@@ -0,0 +1,8 @@
+common --enable_bzlmod
+build --incompatible_strict_action_env
+test --test_output=errors
+
+common --disk_cache=/home/exedev/gazel-port/.cache/bazel-disk
+common --repository_cache=/home/exedev/gazel-port/.cache/bazel-repo
+common --noshow_progress
+test --test_output=errors
diff --git a/BUILD.bazel b/BUILD.bazel
new file mode 100644
index 0000000..a2ac5a7
--- /dev/null
+++ b/BUILD.bazel
@@ -0,0 +1,40 @@
+load("@gazelle//:def.bzl", "gazelle")
+load("@pip//:requirements.bzl", "all_whl_requirements")
+load("@rules_python//python:defs.bzl", "py_library")
+load("@rules_python_gazelle_plugin//manifest:defs.bzl", "gazelle_python_manifest")
+load("@rules_python_gazelle_plugin//modules_mapping:def.bzl", "modules_mapping")
+
+# gazelle:python_root
+# gazelle:python_generation_mode package
+# gazelle:exclude examples
+# gazelle:exclude docs
+# gazelle:exclude tests
+# gazelle:resolve py flask //src/flask
+# gazelle:resolve py _typeshed //:_typeshed_stubs
+# gazelle:resolve py _typeshed.wsgi //:_typeshed_stubs
+# gazelle:resolve py _typeshed.wsgi.StartResponse //:_typeshed_stubs
+# gazelle:resolve py _typeshed.wsgi.WSGIApplication //:_typeshed_stubs
+# gazelle:resolve py _typeshed.wsgi.WSGIEnvironment //:_typeshed_stubs
+
+py_library(
+    name = "_typeshed_stubs",
+    srcs = [],
+    visibility = ["//visibility:public"],
+)
+
+modules_mapping(
+    name = "modules_map",
+    wheels = all_whl_requirements,
+)
+
+gazelle_python_manifest(
+    name = "gazelle_python_manifest",
+    modules_mapping = ":modules_map",
+    pip_repository_name = "pip",
+    requirements = "//:requirements.lock",
+)
+
+gazelle(
+    name = "gazelle",
+    gazelle = "@rules_python_gazelle_plugin//python:gazelle_binary",
+)
diff --git a/EXPECTATIONS.json b/EXPECTATIONS.json
new file mode 100644
index 0000000..bdbcaaf
--- /dev/null
+++ b/EXPECTATIONS.json
@@ -0,0 +1,14 @@
+{
+  "repo": "pallets/flask",
+  "approach_id": "py-native",
+  "scope": "//src/...",
+  "expectations": [
+    {"id":"modgraph","tier":1,"cmd":"bazel mod graph","expect":{"exit":0,"stdout_regex":"rules_python"}},
+    {"id":"pip-hub","tier":1,"cmd":"bazel query '@pip//...' 2>/dev/null","expect":{"allow_nonzero":true}},
+    {"id":"gazelle","tier":1,"cmd":"bazel run //:gazelle","expect":{"exit":0}},
+    {"id":"build","tier":2,"cmd":"bazel build //src/...","expect":{"exit":0}},
+    {"id":"have-pylib","tier":2,"cmd":"bazel query 'kind(\"py_library rule\", //src/...)'","expect":{"exit":0,"stdout_min_lines":1,"stdout_regex":"//src/flask"}},
+    {"id":"have-tests","tier":3,"cmd":"bazel query 'kind(\"py_test rule\", //src/...)'","expect":{"exit":0,"allow_nonzero":true}},
+    {"id":"test","tier":4,"cmd":"bazel test //src/... --test_output=errors","expect":{"exit":0,"allow_nonzero":true}}
+  ]
+}
diff --git a/MODULE.bazel b/MODULE.bazel
new file mode 100644
index 0000000..4f844c9
--- /dev/null
+++ b/MODULE.bazel
@@ -0,0 +1,20 @@
+bazel_dep(name = "rules_python", version = "2.0.2")
+bazel_dep(name = "rules_python_gazelle_plugin", version = "2.0.2")
+bazel_dep(name = "gazelle", version = "0.51.3")
+
+PYTHON_VERSION = "3.12"
+
+python = use_extension("@rules_python//python/extensions:python.bzl", "python")
+python.toolchain(
+    is_default = True,
+    python_version = PYTHON_VERSION,
+)
+use_repo(python, "python_3_12")
+
+pip = use_extension("@rules_python//python/extensions:pip.bzl", "pip")
+pip.parse(
+    hub_name = "pip",
+    python_version = PYTHON_VERSION,
+    requirements_lock = "//:requirements.lock",
+)
+use_repo(pip, "pip")
