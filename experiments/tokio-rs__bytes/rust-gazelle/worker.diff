diff --git a/BUILD.bazel b/BUILD.bazel
new file mode 100644
index 0000000..8d17ae1
--- /dev/null
+++ b/BUILD.bazel
@@ -0,0 +1,15 @@
+load("@gazelle//:def.bzl", "gazelle", "gazelle_binary")
+
+# gazelle:rust_crates_index crates
+
+gazelle_binary(
+    name = "gazelle_bin",
+    languages = [
+        "@gazelle_rust//rust_language",
+    ],
+)
+
+gazelle(
+    name = "gazelle",
+    gazelle = ":gazelle_bin",
+)
diff --git a/EXPECTATIONS.json b/EXPECTATIONS.json
new file mode 100644
index 0000000..e136991
--- /dev/null
+++ b/EXPECTATIONS.json
@@ -0,0 +1,13 @@
+{
+  "repo": "tokio-rs/bytes",
+  "approach_id": "rust-gazelle",
+  "scope": "//...",
+  "expectations": [
+    {"id":"modgraph","tier":1,"cmd":"bazel mod graph","expect":{"exit":0,"stdout_regex":"rules_rust"}},
+    {"id":"gazelle","tier":1,"cmd":"bazel run //:gazelle","expect":{"exit":0}},
+    {"id":"build","tier":2,"cmd":"bazel build //...","expect":{"exit":0}},
+    {"id":"have-lib","tier":2,"cmd":"bazel query 'kind(\"rust_library\", //...)'","expect":{"exit":0,"stdout_min_lines":1}},
+    {"id":"have-tests","tier":3,"cmd":"bazel query 'kind(\"rust_test\", //...)'","expect":{"exit":0,"stdout_min_lines":1,"note":"Repo has 12 integration tests in tests/ (test_buf.rs, test_bytes.rs, etc.) plus a likely lib unit-test target; gazelle_rust should emit rust_test rules for these. Asserting at least one is discovered. serde/odd_alloc/vec_alloc tests are cfg/feature-gated and may be missing if features unmapped (anticipated risk)."}},
+    {"id":"test","tier":4,"cmd":"bazel test //... --test_output=errors","expect":{"exit":0,"allow_nonzero":true,"note":"Cargo feature flags (std/serde/extra-platforms), loom cfg-gated code, and doc tests in src/lib.rs are not run by rust_test and feature mapping by gazelle_rust 0.1.0 may be incomplete; some native integration tests (test_serde, odd/vec_alloc allocator-override tests) may fail to build or run. These are the repo's OWN tests, so we run them, but allow_nonzero given the maturity/feature risks. Predicted realistic tier is 2."}}
+  ]
+}
diff --git a/MODULE.bazel b/MODULE.bazel
new file mode 100644
index 0000000..48b540d
--- /dev/null
+++ b/MODULE.bazel
@@ -0,0 +1,27 @@
+module(
+    name = "bytes",
+    version = "0.0.0",
+)
+
+bazel_dep(name = "rules_rust", version = "0.70.0")
+bazel_dep(name = "gazelle_rust", version = "0.1.0")
+bazel_dep(name = "gazelle", version = "0.51.3")
+bazel_dep(name = "bazel_skylib", version = "1.9.0")
+bazel_dep(name = "platforms", version = "1.1.0")
+
+rust = use_extension("@rules_rust//rust:extensions.bzl", "rust")
+rust.toolchain(
+    edition = "2021",
+    versions = ["1.85.0"],
+)
+use_repo(rust, "rust_toolchains")
+register_toolchains("@rust_toolchains//:all")
+
+crate = use_extension("@rules_rust//crate_universe:extensions.bzl", "crate")
+crate.from_cargo(
+    name = "crates",
+    cargo_lockfile = "//:Cargo.lock",
+    manifests = ["//:Cargo.toml"],
+)
+use_repo(crate, "crates")
+
