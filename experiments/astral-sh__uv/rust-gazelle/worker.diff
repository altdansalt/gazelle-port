diff --git a/BUILD.bazel b/BUILD.bazel
new file mode 100644
index 0000000..fdb4e65
--- /dev/null
+++ b/BUILD.bazel
@@ -0,0 +1,8 @@
+load("@gazelle//:def.bzl", "gazelle")
+
+# gazelle:rust_crates_index crates
+
+gazelle(
+    name = "gazelle",
+    gazelle = "@gazelle_rust//:gazelle_bin",
