diff --git a/EXPECTATIONS.json b/EXPECTATIONS.json
new file mode 100644
index 0000000..a14a52a
--- /dev/null
+++ b/EXPECTATIONS.json
@@ -0,0 +1,15 @@
+{
+  "repo": "astral-sh/uv",
+  "approach_id": "rust-gazelle",
+  "scope": "//crates/...",
+  "expectations": [
+    {"id":"modgraph","tier":1,"cmd":"bazel mod graph","expect":{"exit":0}},
+    {"id":"crate-deps","tier":1,"cmd":"bazel query @crates//:all","expect":{"exit":0,"allow_nonzero":true}},
+    {"id":"gazelle","tier":1,"cmd":"bazel run //:gazelle","expect":{"exit":0}},
+    {"id":"build-smoke","tier":2,"cmd":"bazel build //crates/uv-normalize/...","expect":{"exit":0}},
+    {"id":"build","tier":2,"cmd":"bazel build //crates/...","expect":{"exit":0}},
+    {"id":"have-libs","tier":3,"cmd":"bazel query 'kind(\"rust_library rule\", //crates/...)'","expect":{"exit":0,"stdout_min_lines":1}},
+    {"id":"have-tests","tier":3,"cmd":"bazel query 'kind(\"rust_test rule\", //crates/...)'","expect":{"exit":0,"stdout_min_lines":1}},
+    {"id":"test","tier":4,"cmd":"bazel test //crates/... --test_output=errors","expect":{"exit":0}}
+  ]
+}
diff --git a/MODULE.bazel b/MODULE.bazel
new file mode 100644
index 0000000..c36f885
--- /dev/null
+++ b/MODULE.bazel
@@ -0,0 +1,28 @@
+module(
+    name = "uv",
+    version = "0.0.0",
+)
+
+bazel_dep(name = "rules_rust", version = "0.70.0")
+bazel_dep(name = "gazelle", version = "0.51.3")
+bazel_dep(name = "gazelle_rust", version = "0.1.0")
+bazel_dep(name = "bazel_skylib", version = "1.9.0")
+bazel_dep(name = "platforms", version = "1.1.0")
+bazel_dep(name = "rules_cc", version = "0.2.19")
+
+rust = use_extension("@rules_rust//rust:extensions.bzl", "rust")
+rust.toolchain(
+    edition = "2021",
+    versions = ["1.86.0"],
+)
+use_repo(rust, "rust_toolchains")
+register_toolchains("@rust_toolchains//:all")
+
+crate = use_extension("@rules_rust//crate_universe:extensions.bzl", "crate")
+crate.from_cargo(
+    name = "crates",
+    cargo_lockfile = "//:Cargo.lock",
+    manifests = ["//:Cargo.toml"],
+)
+use_repo(crate, "crates")
+
