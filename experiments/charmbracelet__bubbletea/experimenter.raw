{
  "repo": "charmbracelet/bubbletea",
  "approaches": [
    {
      "id": "go-native",
      "language": "Go",
      "scope": "//...",
      "rationale": "Single-module Go library at the repo root with standard package layout and tests; Gazelle generates the full build+test graph from go.mod. Nested example/tutorial modules are excluded to keep the slice coherent.",
      "module_bazel": "module(\n    name = \"bubbletea\",\n    version = \"0.0.0\",\n)\n\nbazel_dep(name = \"rules_go\", version = \"0.61.1\")\nbazel_dep(name = \"gazelle\", version = \"0.51.3\")\n\ngo_sdk = use_extension(\"@rules_go//go:extensions.bzl\", \"go_sdk\")\ngo_sdk.download(version = \"1.25.4\")\n\ngo_deps = use_extension(\"@gazelle//:extensions.bzl\", \"go_deps\")\ngo_deps.from_file(go_mod = \"//:go.mod\")\n",
      "root_build": "load(\"@gazelle//:def.bzl\", \"gazelle\")\n\n# gazelle:prefix charm.land/bubbletea/v2\n# gazelle:exclude examples\n# gazelle:exclude tutorials\n\ngazelle(name = \"gazelle\")\n",
      "bazelrc": "common --enable_bzlmod\nbuild --incompatible_strict_action_env\n",
      "setup_commands": [
        "bazel run //:gazelle",
        "bazel mod tidy",
        "bazel build //...",
        "bazel test //..."
      ],
      "anticipated_risks": [
        "build-constraints (signals_unix.go/signals_windows.go, termios_*, tty_* platform-specific files)",
        "go:embed",
        "golden-file testdata in tests",
        "cgo (terminal/tty handling may pull in syscall but typically pure-Go)",
        "module path charm.land/bubbletea/v2 must match gazelle:prefix exactly"
      ],
      "predicted_tier": 4
    }
  ]
}
