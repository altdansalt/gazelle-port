diff --git a/.bazelrc b/.bazelrc
new file mode 100644
index 0000000..268214b
--- /dev/null
+++ b/.bazelrc
@@ -0,0 +1,12 @@
+common --enable_bzlmod
+build --action_env=BAZEL_CXXOPTS=-std=c++11
+
+common --disk_cache=/home/exedev/gazel-port/.cache/bazel-disk
+common --repository_cache=/home/exedev/gazel-port/.cache/bazel-repo
+common --noshow_progress
+test --test_output=errors
+
+# Include paths for neovim's dual-root include structure and system libs
+build --copt=-Isrc/nvim
+build --copt=-I/usr/include/luajit-2.1
+build --copt=-I/usr/local/include
diff --git a/BUILD.bazel b/BUILD.bazel
new file mode 100644
index 0000000..f4ae90c
--- /dev/null
+++ b/BUILD.bazel
@@ -0,0 +1,14 @@
+load("@gazelle//:def.bzl", "gazelle")
+
+# gazelle:cc_generate true
+# gazelle:cc_strip_include_prefix /src
+# gazelle:exclude runtime
+# gazelle:exclude cmake.deps
+# gazelle:exclude deps
+# gazelle:exclude src/nvim/generators
+# gazelle:exclude test
+
+gazelle(
+    name = "gazelle",
+    gazelle = "@gazelle_cc//:gazelle_cc",
+)
diff --git a/EXPECTATIONS.json b/EXPECTATIONS.json
new file mode 100644
index 0000000..bc667ee
--- /dev/null
+++ b/EXPECTATIONS.json
@@ -0,0 +1,13 @@
+{
+  "repo": "neovim/neovim",
+  "approach_id": "cpp-gazelle-src",
+  "scope": "src/nvim/...",
+  "expectations": [
+    {"id":"modgraph","tier":1,"cmd":"bazel mod graph","expect":{"exit":0}},
+    {"id":"gazelle","tier":1,"cmd":"bazel run //:gazelle","expect":{"exit":0}},
+    {"id":"build","tier":2,"cmd":"bazel build //src/nvim/...","expect":{"exit":0}},
+    {"id":"have-cc-targets","tier":3,"cmd":"bazel query 'kind(\"cc_library rule\", //src/nvim/...)'","expect":{"exit":0,"stdout_min_lines":1,"note":"gazelle_cc should emit cc_library targets from the include graph; proving structure even if build fails. Not a test query."}},
+    {"id":"have-tests","tier":3,"cmd":"bazel query 'kind(\".*_test rule\", //src/nvim/...)'","expect":{"exit":0,"allow_nonzero":true,"note":"Neovim's own unit/functional tests are Lua (busted) and Lua-bridge C tests driven by CMake/luajit, not native cc_test rules; gazelle_cc will not generate test targets. No native Bazel tests exist in this scope, so tier-3 test discovery is informational only."}},
+    {"id":"test","tier":4,"cmd":"bazel test //src/nvim/... --test_output=errors","expect":{"exit":0,"allow_nonzero":true,"note":"No native cc_test targets in scope (tests are Lua/busted run outside Bazel, and require generated headers + bundled deps libuv/luajit/treesitter that this source-native attempt does not model). Tier-4 cannot be honestly earned; informational only."}}
+  ]
+}
diff --git a/MODULE.bazel b/MODULE.bazel
new file mode 100644
index 0000000..5a1cd6b
--- /dev/null
+++ b/MODULE.bazel
@@ -0,0 +1,18 @@
+module(
+    name = "neovim",
+    version = "0.0.0",
+)
+
+bazel_dep(name = "rules_cc", version = "0.2.19")
+bazel_dep(name = "gazelle_cc", version = "0.6.0")
+bazel_dep(name = "gazelle", version = "0.51.3")
+bazel_dep(name = "platforms", version = "1.1.0")
+bazel_dep(name = "bazel_skylib", version = "1.9.0")
+bazel_dep(name = "rules_go", version = "0.61.1")
+
+cc_configure = use_extension(
+    "@rules_cc//cc:extensions.bzl",
+    "cc_configure_extension",
+)
+use_repo(cc_configure, "local_config_cc")
+
