      "rationale": "fzf is a single-module Go CLI with a clean src/ library tree and unit tests; native rules_go + Gazelle should generate the full build/test graph from go.mod.",
      "module_bazel": "module(\n    name = \"fzf\",\n    version = \"0.0.0\",\n)\n\nbazel_dep(name = \"rules_go\", version = \"0.61.1\")\nbazel_dep(name = \"gazelle\", version = \"0.51.3\")\n\ngo_sdk = use_extension(\"@rules_go//go:extensions.bzl\", \"go_sdk\")\ngo_sdk.download(version = \"1.25.4\")\n\ngo_deps = use_extension(\"@gazelle//:extensions.bzl\", \"go_deps\")\ngo_deps.from_file(go_mod = \"//:go.mod\")\n",
      "root_build": "load(\"@gazelle//:def.bzl\", \"gazelle\")\n\n# gazelle:prefix github.com/junegunn/fzf\ngazelle(name = \"gazelle\")\n",
      "bazelrc": "common --enable_bzlmod\nbuild --incompatible_strict_action_env\ntest --test_output=errors\n",
      "setup_commands": [
        "bazel run //:gazelle",
        "bazel mod tidy",
        "bazel build //...",
        "bazel test //..."
      ],
      "anticipated_risks": [
        "asm-files (src/algo/indexbyte2_*.s) — rules_go handles .s but platform-specific build tags must resolve",
        "platform-specific files (_unix/_windows/_openbsd) — Gazelle should tag-filter correctly",
        "cgo possible in tui/terminal code",
        "go:generate-produced *_string.go files are checked in, so no codegen needed",
        "build-constraint files like result_x86.go / result_others.go may need correct GOARCH selection"
