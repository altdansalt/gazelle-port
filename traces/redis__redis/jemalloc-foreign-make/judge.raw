    {"id":"jemalloc-target-exists","tier":1,"cmd":"bazel query '//:jemalloc'","expect":{"exit":0,"stdout_regex":"//:jemalloc"}},
    {"id":"build-jemalloc","tier":2,"cmd":"bazel build //:jemalloc","expect":{"exit":0}},
    {"id":"foreign-rule-kind","tier":3,"cmd":"bazel query 'kind(\"configure_make rule\", //:all)'","expect":{"exit":0,"stdout_regex":"//:jemalloc"}},
    {"id":"static-lib-output","tier":3,"cmd":"bazel cquery --output=files //:jemalloc","expect":{"exit":0,"stdout_regex":"libjemalloc\\.a"}}
  ]
}
